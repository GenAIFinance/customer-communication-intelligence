# ─────────────────────────────────────────────
# Customer Communication Intelligence Platform
# Environment Variables — copy to .env and fill in
# ─────────────────────────────────────────────

# OpenAI API — leave blank to use stub fallback (no cost)
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-3.5-turbo for cost control)
OPENAI_MODEL=gpt-3.5-turbo

# DuckDB file path (relative to project root)
DUCKDB_PATH=data/processed/communications.duckdb

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit settings
STREAMLIT_PORT=8501

# Data generation settings
SYNTHETIC_ROW_COUNT=5000
RANDOM_SEED=42
